# Replace with your DB credentials!
DATABASE_URL="libsql://db-name-user.turso.io"
DATABASE_AUTH_TOKEN=""
# A local DB can also be used in dev as well
# DATABASE_URL="file:local.db"

# Google API Key for YouTube Data API v3
GOOGLE_API_KEY=""

# Bilibili cookie (optional). Needed for the author-update sweep and any
# risk-controlled endpoints; a logged-in cookie string including SESSDATA.
# Copy the full Cookie header from a logged-in bilibili.com session.
# Note: SESSDATA expires (~1 month) and must be refreshed.
BILIBILI_COOKIE=""